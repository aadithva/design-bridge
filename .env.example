# Azure DevOps
ADO_ORG_URL=https://dev.azure.com/your-org
ADO_PROJECT=YourProject
ADO_REPO_NAME=YourRepo

# Figma
FIGMA_TEAM_IDS=your-team-id
FIGMA_TEAM_NAMES={"your-team-id":"Team Name"}

# Server
PORT=3001

# Storage: "file" (default, persistent JSON files), "memory" (in-process, lost on restart), or "azure-table" (cloud)
STORAGE_BACKEND=file
STORAGE_DIR=./data

# Azure Table Storage (only needed if STORAGE_BACKEND=azure-table)
AZURE_STORAGE_CONNECTION_STRING=

# Webhook automation (server-side PATs for unattended analysis)
WEBHOOK_SECRET=
WEBHOOK_ADO_PAT=
WEBHOOK_FIGMA_PAT=
